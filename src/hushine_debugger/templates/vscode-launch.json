{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hushine Local Replay",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "windows": {
        "python": "${workspaceFolder}/.venv/Scripts/python.exe"
      },
      "module": "hushine_debugger.cli",
      "args": ["replay"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
